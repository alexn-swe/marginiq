# .env.example
#
# This file is safe to commit — it contains NO real secrets.
# It is a template showing which environment variables the app needs.
#
# To get started:
#   1. Copy this file:  cp .env.example .env   (or duplicate it manually on Windows)
#   2. Fill in your real values in .env
#   3. Never commit your .env file (it is already listed in .gitignore)

# ─── Database ─────────────────────────────────────────────────────────────────
#
# PostgreSQL connection string used by Prisma.
#
# Format:
#   postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
#
# Local development examples:
#   postgresql://postgres:password@localhost:5432/marginiq?schema=public
#   postgresql://myuser:mypassword@localhost:5432/marginiq_dev?schema=public
#
# Cloud / hosted examples (Supabase, Railway, Neon, etc.):
#   The provider will give you a connection string — paste it here as-is.
#
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/marginiq?schema=public"
